class Solution(object):
    def isAnagram(self, s, t):
        """
        :type s: str
        :type t: str
        :rtype: bool
        """
        if len(s) != len(t):
            return False
        seens,seent={},{}    
        
        for i in range(len(s)):
            seens[s[i]]=1+seens.get(s[i],0)
            seent[t[i]]=1+seent.get(t[i],0)
        for c in seens:
            if seens[c]!=seent.get(c,0):
                return False
        return True                
