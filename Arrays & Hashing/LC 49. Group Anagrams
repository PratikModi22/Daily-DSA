class Solution(object):
    def groupAnagrams(self, strs):
        """
        :type strs: List[str]
        :rtype: List[List[str]]
        """
        seen ={}
        for words in strs:
            key=''.join(sorted(words))

            if key not in seen:
                seen[key]=[]
            seen[key].append(words)   

        return list(seen.values())    
